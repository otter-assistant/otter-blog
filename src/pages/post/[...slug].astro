---
import { type CollectionEntry, getCollection, render } from "astro:content";
import Tips from "../../components/Tips.astro";
import BlogPost from "../../layouts/BlogPost.astro";
import Backlinks from "../../components/Backlinks.astro";
import { convertMdALinksToGoto, generatePostSlug, filterContent } from "../../utils";
import { findBacklinks } from "../../utils/bidirectionalLinks";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  const filteredPosts = filterContent(posts);

  return filteredPosts
    .map((post) => ({
      params: {
        slug: generatePostSlug(post) + ".html",
      },
      props: { post, allPosts: filteredPosts },
    }));
}
type Props = { post: CollectionEntry<"blog">, allPosts: CollectionEntry<"blog">[] };

let { post, allPosts } = Astro.props;
const { Content, headings } = await render(post);
const isTempUrl = !post.data?.uri;
const backlinks = findBacklinks(post.id, allPosts);
---

<BlogPost
  {...post.data}
  date={post.data.date.toISOString()}
  updated={post.data.updated?.toISOString()}
  originalId={post.id}
>
  {
    isTempUrl && (
      <Tips type="warning">这是一个临时URL，可能在后续被移除或更改。</Tips>
    )
  }
  <Content />
  <Backlinks backlinks={backlinks} />
</BlogPost>
