---
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import { generateCategorySlug, filterContent } from "../../utils";

const posts = filterContent(await getCollection("blog"));

const categoryMap = new Map<string, number>();
for (const post of posts) {
  const category = post.data.categories;
  if (category) {
    categoryMap.set(category, (categoryMap.get(category) || 0) + 1);
  }
}

const categories = Array.from(categoryMap.entries())
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count || a.name.localeCompare(b.name));

// Speculation Rules: prerender common navigation pages
const speculationUrls = [
  "/",           // Home page
  "/post",       // Posts listing
  "/tags",       // Tags listing
  "/archives",   // Archives page
];
// Add URLs for top categories
categories.slice(0, 5).forEach(({ name }) => {
  speculationUrls.push(`/categories/${generateCategorySlug(name)}`);
});
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead
      title={`${SITE_TITLE} · Categories`}
      description={SITE_DESCRIPTION}
      speculationUrls={speculationUrls}
      speculationEagerness="moderate"
    />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1 w-full max-w-285 mx-auto px-4 py-12">
      <section>
        <h1 class="m-0 mb-6 text-xl font-bold text-gray-900 dark:text-gray-100">
          所有分类
        </h1>
        {
          categories.length === 0 ? (
            <p class="text-gray-600 dark:text-gray-300">暂无分类。</p>
          ) : (
            <ul class="flex gap-2 flex-wrap list-none m-0 p-0">
              {categories.map(({ name, count }) => (
                <li>
                  <a
                    href={`/categories/${generateCategorySlug(name)}`}
                    class="inline-block bg-primary/10 text-primary text-sm px-3 py-1.5 rounded hover:bg-primary/20 transition-colors dark:bg-primary/20 dark:text-primary/90"
                  >
                    {name} <span class="opacity-70">({count})</span>
                  </a>
                </li>
              ))}
            </ul>
          )
        }
      </section>
    </main>
    <Footer />
  </body>
</html>
