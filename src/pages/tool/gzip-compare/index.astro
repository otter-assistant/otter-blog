---
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../../consts';
import '../../../styles/global.css';

const speculationUrls = ["/", "/post", "/categories", "/tags", "/archives"];
---

<!doctype html>
<html lang="zh-CN" class="scroll-smooth">
  <head>
    <BaseHead
      title={`${SITE_TITLE} · Gzip 对比`}
      description="对比两段文本的 Gzip 压缩率"
      speculationUrls={speculationUrls}
      speculationEagerness="moderate"
    />
  </head>
  <body>
    <Header />
    <main class="w-full max-w-4xl mx-auto px-4 py-12">
      <section class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-4">
          Gzip 压缩率对比
        </h1>
        <p class="text-gray-600 dark:text-gray-400">
          输入两段文本，实时对比它们的 Gzip 压缩率和大小
        </p>
      </section>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
        <div class="space-y-4">
          <label class="block">
            <span class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2 block">
              文本 A
            </span>
            <textarea
              id="text-a"
              rows="10"
              placeholder="输入第一段文本..."
              class="w-full px-4 py-3 border-2 border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-900 text-gray-900 dark:text-gray-100 placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors resize-none"
            ></textarea>
          </label>

          <div
            id="result-a"
            class="p-4 bg-primary/5 dark:bg-primary/10 border border-primary/20 dark:border-primary/30 rounded-lg min-h-[120px]"
          >
            <p class="text-gray-400">请输入文本</p>
          </div>
        </div>

        <div class="space-y-4">
          <label class="block">
            <span class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2 block">
              文本 B
            </span>
            <textarea
              id="text-b"
              rows="10"
              placeholder="输入第二段文本..."
              class="w-full px-4 py-3 border-2 border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-900 text-gray-900 dark:text-gray-100 placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-colors resize-none"
            ></textarea>
          </label>

          <div
            id="result-b"
            class="p-4 bg-primary/5 dark:bg-primary/10 border border-primary/20 dark:border-primary/30 rounded-lg min-h-[120px]"
          >
            <p class="text-gray-400">请输入文本</p>
          </div>
        </div>
      </div>

      <div
        id="comparison"
        class="p-6 bg-gradient-to-r from-primary/5 to-primary/10 dark:from-primary/10 dark:to-primary/20 border-2 border-primary/20 dark:border-primary/30 rounded-lg"
      >
        <p class="text-gray-400 text-center">输入文本后查看对比结果</p>
      </div>

      <div class="mt-8 p-4 bg-slate-50 dark:bg-slate-800/50 rounded-lg">
        <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">
          说明
        </h3>
        <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-1 list-disc list-inside">
          <li>使用浏览器原生 CompressionStream API 计算 Gzip 大小（不支持时自动降级到 fflate 库）</li>
          <li>压缩率 = Gzip 后大小 / 原始大小（越小越好）</li>
          <li>节省 = 1 - 压缩率（越大越好）</li>
          <li>
            小文本压缩后可能变大：Gzip 有固定的封装开销（header + footer + 元数据），当原始内容很短时（例如 10B），压缩后可能变成 20-30B，这是正常现象；文本越长、重复度越高，压缩效果越明显
          </li>
        </ul>
      </div>
    </main>
    <Footer />

    <script>
      import { initGzipCompare } from "../../../scripts/gzip-compare.ts";
      initGzipCompare();
    </script>
  </body>
</html>
