---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import '../../styles/global.css';

const speculationUrls = ['/', '/post', '/categories', '/tags', '/archives'];

const tools = [
  {
    name: 'URL 重定向',
    href: '/tool/goto',
    description: '安全的外链跳转工具，支持所有 URI 协议',
  },
  {
    name: 'Gzip 压缩率对比',
    href: '/tool/gzip-compare',
    description: '输入两段文本，实时对比它们的 Gzip 压缩率和大小',
  },
];
---

<!doctype html>
<html lang="zh-CN" class="scroll-smooth">
  <head>
    <BaseHead
      title={`${SITE_TITLE} · Tools`}
      description="在线工具集合"
      speculationUrls={speculationUrls}
      speculationEagerness="moderate"
    />
  </head>
  <body>
    <Header />
    <main class="w-full max-w-4xl mx-auto px-4 sm:px-6 py-10 text-base leading-relaxed">
      <div class="mb-8">
        <h1 class="text-3xl sm:text-4xl font-semibold tracking-tight text-slate-900 dark:text-slate-100">
          Tools
        </h1>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
          在线工具集合，帮助你完成日常任务
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-2">
        {tools.map((tool) => (
          <a
            href={tool.href}
            class="no-style group block p-4 rounded-lg transition-colors hover:bg-primary/20 dark:hover:bg-primary/20"
          >
            <h2 class="text-base font-medium text-slate-900 dark:text-slate-100 group-hover:text-primary dark:group-hover:text-primary transition-colors">
              {tool.name}
            </h2>
            <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
              {tool.description}
            </p>
          </a>
        ))}
      </div>
    </main>
    <Footer />
  </body>
</html>
