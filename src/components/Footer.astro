---
import config from "../config";
import FooterLinks from "./FooterLinks.astro";
import { generateColorFromHash } from "../utils/index";
import { processLink } from "../utils/goto";
import SearchModal from "./SearchModal.astro";

const today = new Date();

// 获取版本信息
const version = import.meta.env.__version__;
const isDev = import.meta.env.DEV;

// 构建版本链接（固定为指定的 tree URL，versionHash 保持动态用于显示）
let versionLink = "https://github.com/otter-assistant/otter-blog/tree/main";
let versionHash = "dev";

if (isDev) {
  versionLink = "https://github.com/otter-assistant/otter-blog/tree/main";
  versionHash = "dev";
} else if (version && version !== 'unknown') {
  // 当存在版本哈希时，使用对应的 tree URL（随 git 哈希 跟随）
  versionLink = `https://github.com/otter-assistant/otter-blog/tree/${version}`;
  versionHash = version;
}

// 根据哈希生成颜色
const hashColor = generateColorFromHash(versionHash);

// 处理外链
const processedVersionLink = processLink(versionLink);
const astroLink = processLink("https://astro.build/");
const githubLink = processLink("https://github.com/otter-assistant");
---

<footer
  class="py-24 px-4 text-center text-gray-500 dark:text-gray-400 bg-linear-to-b from-gray-50 to-white dark:from-gray-800 dark:to-gray-900 transition-colors"
>
  <div>
    <div>
      &copy; {today.getFullYear()} Otter All rights reserved.
    </div>
    <div>
      Built on <a
        class="no-underline!"
        href={processedVersionLink}
        target="_blank">obsidian2astro-template<span class="version-hash" style={`color: ${hashColor};`} data-hash-color={hashColor}>#{versionHash}</span></a
      > / <a class="no-underline!" href={astroLink} target="_blank"
        >Astro</a
      >
    </div>
    <div class="social-links flex justify-center gap-4 mt-4">
      <a
        href={githubLink}
        target="_blank"
        class="no-underline text-gray-500 dark:text-gray-400 hover:bg-primary/10 dark:hover:bg-primary/20 p-2 rounded transition-colors"
      >
        <span class="sr-only">Go to Eeymoo's GitHub</span>
        <svg
          viewBox="0 0 16 16"
          aria-hidden="true"
          width="32"
          height="32"
          astro-icon="social/github"
          ><path
            fill="currentColor"
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
          ></path></svg
        >
      </a>
    </div>
  </div>
  <div>
    <FooterLinks links={config.friendlyLink} />
  </div>
  <SearchModal hidden={true} />
</footer>
