---
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"a"> & {
  /** 正则表达式字符串，用于匹配当前路径 */
  activePattern?: string;
};

const { href = "", class: className, activePattern, ...props } = Astro.props;
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, "");
const hrefWithoutExt = String(href).replace(/\.html$/, "");
const pathnameWithoutExt = pathname.replace(/\.html$/, "");
const subpath = pathnameWithoutExt.match(/[^\/]+/g);

// 正则表达式匹配
const regexMatch = activePattern ? new RegExp(activePattern).test(pathnameWithoutExt) : false;

const isActive =
  hrefWithoutExt === pathnameWithoutExt ||
  hrefWithoutExt === "/" + (subpath?.[0] || "") ||
  regexMatch;
---

<a
  href={href}
  class:list={[
    className,
    "no-style nav-link px-2 mx-2 my-2 text-gray-700 dark:text-gray-300 underline hover:bg-primary/10 dark:hover:bg-primary/20 transition-colors rounded",
    {
      "font-black decoration-primary! active-link": // 选中状态额外添加 active-link 类
        isActive,
    },
  ]}
  {...props}
>
  <slot />
</a>
