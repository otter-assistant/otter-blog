---
import { type CollectionEntry } from 'astro:content';
import { generatePostSlug } from '../utils';

interface Props {
  backlinks: CollectionEntry<'blog'>[];
}

const { backlinks } = Astro.props;
---

{backlinks.length > 0 && (
  <details class="mt-12 pt-8 border-t border-slate-200 dark:border-slate-800 group">
    <summary class="cursor-pointer text-base text-slate-600 dark:text-slate-400 hover:text-primary dark:hover:text-primary transition-colors list-none flex items-center gap-2">
      <svg class="w-4 h-4 transform transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
      </svg>
      <span>反向链接({backlinks.length}条)</span>
    </summary>
    <ul class="mt-4 space-y-2 pl-6">
      {backlinks.map((post) => (
        <li>
          <a
            href={`/post/${generatePostSlug(post)}.html`}
            class="text-base text-slate-700 dark:text-slate-300 hover:text-primary dark:hover:text-primary transition-colors"
          >
            {post.data.title}
          </a>
        </li>
      ))}
    </ul>
  </details>
)}
